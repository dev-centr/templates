{
	"folders": [
		{
			"path": "."
		}
	],
	"settings": {
		// Prevent VS Code from automatically detecting all git repos in the workspace
		"git.autoRepositoryDetection": false,

		"files.exclude": {
			"**/.git": false
		},

		// Standard formatting settings
		"editor.tabSize": 2,
		"editor.formatOnSave": true,
		"editor.defaultFormatter": "biomejs.biome",

		// Language specific settings
		"[asciidoc]": {
			"editor.wordWrap": "on"
		},
		"[markdown]": {
			"editor.wordWrap": "on",
			"editor.defaultFormatter": "yzhang.markdown-all-in-one",
			"editor.formatOnSave": true
		},
		"[yaml]": {
			"editor.defaultFormatter": "redhat.vscode-yaml"
		},

		// IMPORTANT: Language-specific overrides are required to ensure workspace settings 
		// take precedence over any individual User-level language defaults (like Prettier).
		"[json]": {
			"editor.defaultFormatter": "biomejs.biome"
		},
		"[jsonc]": {
			"editor.defaultFormatter": "biomejs.biome"
		},
		"[code-workspace]": {
			"editor.defaultFormatter": "biomejs.biome"
		},
	},
	"extensions": {
		"recommendations": [
			"asciidoctor.asciidoctor-vscode",
			"biomejs.biome",
			"yzhang.markdown-all-in-one",
			"DavidAnson.vscode-markdownlint",
			"bpruitt-goddard.mermaid-markdown-syntax-highlighting",
			"bierner.markdown-mermaid",
			"redhat.vscode-yaml",
		]
	}
}
